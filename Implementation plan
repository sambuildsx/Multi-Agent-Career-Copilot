8. Database Schema
sql-- Users
CREATE TABLE users (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    email       TEXT UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,
    created_at  TIMESTAMPTZ DEFAULT NOW()
);

-- Analysis Jobs
CREATE TABLE analysis_jobs (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID REFERENCES users(id) ON DELETE CASCADE,
    status          TEXT NOT NULL DEFAULT 'pending',
                    -- pending | running | completed | failed | partial
    resume_path     TEXT,
    jd_text         TEXT,
    github_input    TEXT,
    celery_task_id  TEXT,
    created_at      TIMESTAMPTZ DEFAULT NOW(),
    completed_at    TIMESTAMPTZ
);

-- Agent Results (one row per agent per job, written incrementally)
CREATE TABLE agent_results (
    id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    job_id      UUID REFERENCES analysis_jobs(id) ON DELETE CASCADE,
    agent_name  TEXT NOT NULL,  -- resume | jd | ats | github
    status      TEXT NOT NULL,  -- running | completed | failed
    result_json JSONB,
    error_msg   TEXT,
    completed_at TIMESTAMPTZ
);

-- Final Reports
CREATE TABLE final_reports (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    job_id          UUID REFERENCES analysis_jobs(id) ON DELETE CASCADE UNIQUE,
    resume_score    INT,
    ats_score       INT,
    github_score    INT,
    report_json     JSONB NOT NULL,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

-- Indexes
CREATE INDEX idx_jobs_user ON analysis_jobs(user_id);
CREATE INDEX idx_results_job ON agent_results(job_id);

