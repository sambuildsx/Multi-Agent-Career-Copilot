# ==============================================================================
# Recruiter Copilot Backend Configuration - Example Environment Variables
# Copy this file to '.env' and fill in your custom values.
# ==============================================================================

# Core Project Information
PROJECT_NAME="Career Copilot"
ENVIRONMENT="development" # development | production

# Database Configuration
# Defaults to sqlite inside the workspace. Change to PostgreSQL if needed.
DATABASE_URL="sqlite+aiosqlite:///careeros.db"
DB_ECHO=false

# Security (Required)
# Run `openssl rand -hex 32` or type a secure random string to generate one
SECRET_KEY="your-jwt-secret-key-goes-here"

# Google Gemini API Configuration (Required)
# Retrieve your key from Google AI Studio (https://aistudio.google.com/)
GOOGLE_API_KEY="AIzaSy..."
GEMINI_MODEL="gemini-2.5-flash"

# File Upload Configuration
UPLOAD_DIRECTORY="uploads"

# CORS Configuration
# Comma-separated list of frontends allowed to connect
ALLOWED_ORIGINS=["http://localhost:5173"]
